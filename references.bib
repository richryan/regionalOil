@Article{squires_vestergaard_2013,
  author   = {Dale Squires and Niels Vestergaard},
  journal  = {The Review of Economics and Statistics},
  title    = {{Technical Change and The Commons}},
  year     = {2013},
  month    = {December},
  number   = {5},
  pages    = {1769-1787},
  volume   = {95},
  abstract = {This paper addresses normative exploitation of common renewable resources with changes in technology and technical, allocative, and scale efficiency that exacerbate the commons problem and externality. Their impact depends on the rate and nature of change, investment, and state of property rights. An augmented fundamental equation of renewable resources with a modified marginal stock effect and a new marginal technology effect account for changes in disembodied and embodied technology and technical efficiency. Neglecting these changes generates misleading policy advice and dynamic inefficiency with overaccumulation of physical and natural capital and sizable foregone rents. An empirical application illustrates.    2013 The President and Fellows of Harvard College and the Massachusetts Institute of Technology.},
