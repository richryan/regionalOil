@Article{ball_leigh_loungani_2017,
  author   = {Ball, Laurence and Leigh, Daniel and Loungani, Prakash},
  journal  = {Journal of Money, Credit and Banking},
  title    = {Okun's Law: Fit at 50?},
  year     = {2017},
  number   = {7},
  pages    = {1413-1441},
  volume   = {49},
  abstract = {Abstract This paper asks how well Okun's Law fits short-run unemployment movements in the United States since 1948 and in 20 advanced economies since 1980. We find that Okun's Law is a strong relationship in most countries, and one that is fairly stable over time. Accounts of breakdowns in the Law, such as the emergence of “jobless recoveries,” are flawed or exaggerated. We also find that the coefficient in the relationship—the effect of a 1\% change in output on the unemployment rate—varies substantially across countries. This variation is partly explained by idiosyncratic features of national labor markets, but it is not related to differences in employment protection legislation.},
  doi      = {10.1111/jmcb.12420},
  eprint   = {https://onlinelibrary.wiley.com/doi/pdf/10.1111/jmcb.12420},
  keywords = {E24, E32, unemployment, Okun's Law, economic fluctuations},
  url      = {https://onlinelibrary.wiley.com/doi/abs/10.1111/jmcb.12420},
}

