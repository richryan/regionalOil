@article{barlevy_2008,
author = {Barlevy, Gadi}, 
title = {Identification of Search Models using Record Statistics},
volume = {75}, 
number = {1}, 
pages = {29-64}, 
year = {2008}, 
doi = {10.1111/j.1467-937X.2007.00459.x}, 
abstract ={This paper shows how record-value theory, a branch of statistics that deals with the timing and magnitude of extreme values in sequences of random variables, can be used to recover features of the wage offer distribution in conventional search models. Using National Longitudinal Survey of Youth (NLSY) wage data, I show that the data are not compatible with specifications for the offer distribution characterized by extreme negative skewness. In addition, I show that my approach can be used to construct a bound on the returns to job seniority. My results suggest that job seniority plays only a minor role in the wage growth of the workers surveyed in the NLSY.}, 
URL = {http://restud.oxfordjournals.org/content/75/1/29.abstract}, 
eprint = {http://restud.oxfordjournals.org/content/75/1/29.full.pdf+html}, 
journal = {The Review of Economic Studies} 
}

@Article{altig_etal_2011,
  author   = {David Altig and Lawrence J. Christiano and Martin Eichenbaum and Jesper Lind},
  journal  = {Review of Economic Dynamics},
  title    = {Firm-specific capital, nominal rigidities and the business cycle},
  year     = {2011},
  issn     = {1094-2025},
  number   = {2},
  pages    = {225 - 247},
  volume   = {14},
  abstract = {This paper formulates and estimates a three-shock U.S. business cycle model. The estimated model accounts for a substantial fraction of the cyclical variation in output and is consistent with the observed inertia in inflation. This is true even though firms in the model re-optimize prices on average once every 1.8 quarters. The key feature of our model underlying this result is that capital is firm-specific. If we adopt the standard assumption that capital is homogeneous and traded in economy-wide rental markets, we find that firms re-optimize their prices on average once every 9 quarters. We argue that the micro implications of the model strongly favor the firm-specific capital specification.},
  doi      = {http://dx.doi.org/10.1016/j.red.2010.01.001},
  keywords = {Sticky prices and wages, Inflation inertia, Monetary policy shocks, Neutral and investment-specific technology shocks, Structural vector autoregressive (VAR) model},
  url      = {http://www.sciencedirect.com/science/article/pii/S1094202510000025},
}

@Article{faria_etal_201,
  author   = {Jo{\H{a}}o Ricardo Faria and Andr{\'{e}} Varella Mollick and Adolfo Sachsida and Le Wang},
  journal  = {International Review of Economics & Finance},
  title    = {Do central banks affect Tobin's q},
  year     = {2012},
  issn     = {1059-0560},
  number   = {1},
  pages    = {1 - 10},
  volume   = {22},
  abstract = {Previous work has documented inflation effects on Tobin's q in the long run. This paper examines whether the FED's different policies and chairmen tenure have an impact on Tobin's q, after a modified stylized AD-AS model shows that central banks affect q. We do find changing responses of q depending on the pre-Volcker and post-Volcker periods.},
  doi      = {http://dx.doi.org/10.1016/j.iref.2011.08.003},
  keywords = {Central bank, Tobin's q, U.S. Federal Reserve},
  url      = {http://www.sciencedirect.com/science/article/pii/S105905601100089X},
}

