@article{manski_1993,
  ISSN = {0034-6527},
  abstract = {This paper examines the reflection problem that arises
  when a researcher observing the distribution of behaviour in a
  population tries to infer whether the average behaviour in some
  group influences the behaviour of the individuals that comprise the
  group. It is found that inference is not possible unless the
  researcher has prior information specifying the composition of
  reference groups. If this information is available, the prospects
  for inference depend critically on the population relationship
  between the variables defining reference groups and those directly
  affecting outcomes. Inference is difficult to impossible if these
  variables are functionally dependent or are statistically
  independent. The prospects are better if the variables defining
  reference groups and those directly affecting outcomes are
  moderately related in the population.},
  author = {Manski, Charles F.},
  copyright = {Copyright 1993 The Review of Economic Studies Ltd.},
  journal = {The Review of Economic Studies},
  jstor_articletype = {Full Length Article},
