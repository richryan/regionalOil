@Article{elsby_michaels_ratner_2015_detailed,
  author    = {Michael W. L. Elsby and Ryan Michaels and David Ratner},
  journal   = {Journal of Economic Literature},
  title     = {The Beveridge Curve: A Survey},
  year      = {2015},
  issn      = {00220515},
  number    = {3},
  pages     = {571--630},
  volume    = {53},
  abstract  = {Important progress has been made in economists' understanding of the Bevendge curve, from its measurement to its expression in canonical labor market models. Yet endunng puzzles remain. Chief among these are the empincal role of vacancies in the recruitment process; the amplitude, comovement, and persistence of cyclical unemployment-vacancy dynamics; and the sources of lateral shifts in the Bevendge curve. The synthesis of these themes identifies several pnorítiesfor ongoing research, including the role of entry costs into vacancy creation in shaping Bevendge dynamics; the cyclicality of search intensity, both off and on the job, and its relation to participation and job-to-job transitions; the theory and measurement of mismatch; and the sources of hysteresis in unemployment flows.},
  publisher = {American Economic Association},
  url       = {http://www.jstor.org/stable/43932406},
}

