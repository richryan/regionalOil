@Article{howitt_1988,
  author    = {Peter Howitt},
  journal   = {The Quarterly Journal of Economics},
  title     = {Business Cycles with Costly Search and Recruiting},
  year      = {1988},
  issn      = {00335533, 15314650},
  number    = {1},
  pages     = {147--165},
  volume    = {103},
  abstract  = {A business cycle model is developed in which output is traded on Lucas-Phelps islands and labor services on each island are exchanged through costly search and recruiting with transactions externalities. The model exhibits persistent involuntary unemployment and inefficient equilibria, even though there are no nominal rigidities and no unexploited privately attainable gains from trade. It also exhibits employment fluctuations without any real-wage fluctuations. It yields a Lucas aggregate supply curve (to a linear approximation). It also implies that the natural rate of unemployment depends positively upon the variability and persistence of relative price shocks.},
  file      = {:howitt_1988.pdf:PDF},
  groups    = {CARES Act and McCall Search},
  priority  = {prio1},
  publisher = {Oxford University Press},
  url       = {http://www.jstor.org/stable/1882646},
}

@Article{wright_loberg_1987,
  author     = {Randall Wright and Janine Loberg},
  journal    = {The Canadian Journal of Economics},
  title      = {Unemployment Insurance, Taxes, and Unemployment},
  year       = {1987},
  issn       = {00084085, 15405982},
  number     = {1},
  pages      = {36--54},
  volume     = {20},
  abstract   = {Unemployment insurance is financed by a tax on wages below a given ceiling. Hamermesh advocates raising this ceiling on distributional grounds. In a job search model this does decrease unemployment among low-wage workers but also increases unemployment among high-wage workers and lowers everyone's expected after-tax wage. An increase in the ceiling combined with a proportionate reduction in the tax rate decreases unemployment for low-wage workers while increasing their after-tax wage, without affecting high-wage workers at all. When unemployment benefits and wages are taxed at one rate, employment and wages are independent of that rate.},
  file       = {:wright_loberg_1987.pdf:PDF},
  groups     = {CARES Act and McCall Search},
  priority   = {prio1},
  publisher  = {Wiley, Canadian Economics Association},
  readstatus = {skimmed},
