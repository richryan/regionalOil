@techreport{hall_2007,
 title = "Measuring the Returns to R&D: The Depreciation Problem",
 author = "Bronwyn H. Hall",
 institution = "National Bureau of Economic Research",
 type = "Working Paper",
 series = "Working Paper Series",
 number = "13473",
 year = "2007",
 month = "October",
 doi = {10.3386/w13473},
 URL = "http://www.nber.org/papers/w13473",
 abstract = {Measuring the private returns to R&D requires knowledge of its private depreciation or obsolescence rate, which is inherently variable and responds to competitive pressure. Nevertheless, most of the previous literature has used a constant depreciation rate to construct R&D capital stocks and measure the returns to R&D, a rate usually equal to 15 per cent. In this paper I review the implications of this assumption for the measurement of returns using two different methodologies: one based on the production function and another that uses firm market value to infer returns. Under the assumption that firms choose their R&D investment optimally, that is, marginal expected benefit equals marginal cost, I show that both estimates of returns can be inverted to derive an implied depreciation rate for R&D capital. I then test these ideas on a large unbalanced panel of U.S. manufacturing firms for the years 1974 to 2003. The two methods do not agree, in that the production function approach suggests depreciation rates near zero (or even appreciation) whereas the market value approach implies depreciation rates ranging from 20 to 40 per cent, depending on the period. The concluding section discusses the possible reasons for this funding.},
}

@article{bhall_2005,
 ISSN = {0769489X, 22726497},
 URL = {http://www.jstor.org/stable/20777581},
 abstract = {Measuring the private returns to R&D requires knowledge of its private depreciation or obsolescence rate, which is inherently variable and responds to competitive pressure. Nevertheless, most of the previous literature has used a constant depreciation rate to construct R&D capital stocks and measure the returns to R&D, a rate usually equal to 15 per cent. In this paper I review the implications of this assumption for the measurement of returns using two different methodologies: one based on the production function and another that uses firm market value to infer returns. Under the assumption that firms choose their R&D investment optimally, that is, marginal expected benefit equals marginal cost, I show that both estimates of returns can be inverted to derive an implied depreciation rate for R&D capital. I then test these ideas on a large unbalanced panel of U.S. manufacturing firms for the years 1974 to 2003. The two methods do not agree, in that the production function approach suggests depreciation rates near zero (or even appreciation) whereas the market value approach implies depreciation rates ranging from 20 to 40 per cent, depending on the period. The concluding section discusses the possible reasons for this finding. La mesure des rendements priv  s de la R&D requiert une connaissance de sa d  pr  ciation priv  e ou de son taux d'obsolescence, qui est intrins  quement variable et r  agit aux pressions de la concurrence. N  anmoins, l'essentiel de la litt  rature a utilis   un taux de d  pr  ciation constant pour construire des stocks de capital de R&D et mesurer ses rendements: un taux habituellement pos     gal    15 pour cent. Dans cet article, je passe en revue les implications de cette hypoth  se pour la mesure des rendements en utilisant deux m  thodologies diff  rentes: l'une, fond  e sur la fonction de production; l'autre, qui utilise la valeur de march   de l'entreprise pour en inf  rer les rendements. Sous l'hypoth  se que les entreprises choisissent leur investissement en R&D de mani  re optimale, c'est    dire, en   galisant b  n  fice esp  r   marginal et co  t marginal, je montre que les deux estimations des rendements peuvent   tre invers  es pour en d  duire un taux de d  pr  ciation implicite pour le capital de R&D. Je teste ensuite ces id  es sur un panel non-cylindr   de grande taille d'entreprises industrielles am  ricaines pour les ann  es 1974    2003. Les deux m  thodes donnent des r  sultats diff  rents. La m  thode de la fonction de production sugg  re des taux de d  pr  ciation proches de z  ro (ou m  me des taux d'appr  ciation) tandis que l'approche par la valeur de march   implique des taux de d  pr  ciation de l'ordre de 20    40 pour cent, suivant la p  riode consid  r  e. La conclusion propose une discussion des raisons qui pourraient expliquer ce r  sultat.},
 author = {Bronwyn H. HALL},
 journal = {Annales d'  conomie et de Statistique},
 number = {79/80},
 pages = {341-381},
 publisher = {[GENES, ADRES]},
 title = {Measuring the Returns to R&D: The Depreciation Problem},
 year = {2005}
}

@Article{edelstein_kilian_2009,
  author   = {Paul Edelstein and Lutz Kilian},
  journal  = {Journal of Monetary Economics},
  title    = {How sensitive are consumer expenditures to retail energy prices},
  year     = {2009},
  issn     = {0304-3932},
  number   = {6},
  pages    = {766-779},
  volume   = {56},
  abstract = {There is growing evidence that the primary effect of energy price shocks on the U.S. economy involves a reduction in consumer spending. We quantify the direct effect on real consumption of unanticipated changes in discretionary income, shifts in precautionary savings, and changes in the operating cost of energy-using durables. The possibility of asymmetries in the response of real consumption to energy price shocks is also considered. We demonstrate that linear models are consistent with the symmetric behavior of real consumption in 1979 (when energy prices increased sharply) and in 1986 (when they fell sharply). It is shown that historically energy price shocks have been an important factor in explaining U.S. real consumption growth, but by no means the dominant factor.},
  doi      = {http://dx.doi.org/10.1016/j.jmoneco.2009.06.001},
  keywords = {Energy prices, Consumption, Consumer sentiment, Purchasing power, Asymmetry},
  url      = {http://www.sciencedirect.com/science/article/pii/S0304393209000762},
}

@article{kilian_2008,
 ISSN = {00220515},
 URL = {http://www.jstor.org/stable/27647084},
 abstract = {Large fluctuations in energy prices have been a distinguishing characteristic of the U.S. economy since the 1970s. Turmoil in the Middle East, rising energy prices in the United States, and evidence of global warming recently have reignited interest in the link between energy prices and economic performance. This paper addresses a number of the key issues in this debate: What are energy price shocks and where do they come from  How responsive is energy demand to changes in energy prices  How do consumer's expenditure patterns evolve in response to energy price shocks  How do energy price shocks affect U.S. real output, inflation, and stock prices  Why do energy price increases seem to cause recessions but energy price decreases do not seem to cause expansions  Why has there been a surge in the price of oil in recent years  Why has this new energy price shock not caused a recession so far  Have the effects of energy price shocks waned since the 1980s and, if so, why  As the paper demonstrates, it is critical to account for the endogeneity of energy prices and to differentiate between the effects of demand and supply shocks in energy markets when answering these questions.},
 author = {Lutz Kilian},
 journal = {Journal of Economic Literature},
 number = {4},
 pages = {871-909},
 publisher = {American Economic Association},
 title = {The Economic Effects of Energy Price Shocks},
 volume = {46},
 year = {2008}
}

