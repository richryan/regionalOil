  title = {Exit, Voice, and the Fate of the German Democratic Republic: An Essay in Conceptual History},
  url = {http://links.jstor.org/sici sici=0043-8871%28199301%2945%3A2%3C173%3AEVATFO%3E2.0.CO%3B2-M},
  volume = {45},
