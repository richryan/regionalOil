  journal  = {Journal of Economic Theory},
  title    = {Linear-quadratic approximation of optimal policy problems},
  year     = {2012},
  issn     = {0022-0531},
  number   = {1},
  pages    = {1--42},
  volume   = {147},
  abstract = {We consider a general class of nonlinear optimal policy problems with forward-looking constraints, and show how to derive a problem with linear constraints and a quadratic objective that approximates the exact problem. The solution to the \{LQ\} approximate problem represents a local linear approximation to optimal policy from the    timeless perspective   proposed in Benigno and Woodford (2004, 2005) [6,7], in the case of small enough stochastic disturbances. We also derive the second-order conditions for the \{LQ\} problem to have a solution, and show how to correctly rank alternative simple policy rules, again in the case of small enough shocks.},
  doi      = {http://dx.doi.org/10.1016/j.jet.2011.10.012},
  keywords = {Perturbation methods, Timeless perspective, Policy rules},
  url      = {http://www.sciencedirect.com/science/article/pii/S0022053111001451},
}

