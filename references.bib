@Article{weil_2007,
  author = 	 {David N. Weil},
  title = 	 {Accounting for the Effect of Health on Economic
                  Growth},
  journal = 	 {Quarterly Journal of Economics},
  year = 	 {2007},
  volume = 	 {122},
  number = 	 {3},
  pages = 	 {1265--1306},
  month = 	 {August},
  annote = {I use microeconomic estimates of the effect of health on
individual outcomes to construct macroeconomic estimates of the
proximate effect of health on GDP per capita. I employ a variety of
methods to construct estimates of the return to health, which I
combine with cross-country and historical data on height, adult
survival rates, and age at menarche. Using my preferred estimate,
eliminating health differences among countries would reduce the
variance of log GDP per worker by 9.9 percent and reduce the ratio of
GDP per worker at the 90th percentile to GDP per worker at the 10th
percentile from 20.5 to 17.9. While this effect is economically
significant, it is also substantially smaller than estimates of the
effect of health on economic growth that are derived from
cross-country regressions.}
}

