@Article{elsby_hobijn_sahin_2015,
  author   = {Michael W. L. Elsby and Bart Hobijn and Ay\c{s}eg{\"{u}l} \c{S}ahin},
  journal  = {Journal of Monetary Economics},
  title    = {On the importance of the participation margin for labor market fluctuations},
  year     = {2015},
  issn     = {0304-3932},
  pages    = {64-82},
  volume   = {72},
  abstract = {Abstract Conventional analyses of labor market fluctuations ascribe a minor role to labor force participation. We show, by contrast, that flows-based analyses imply that the participation margin accounts for around one-third of unemployment fluctuations. A novel stock-flow apparatus establishes these facts, delivering three further contributions. First, the role of the participation margin appears robust to adjustments for spurious transitions induced by reporting error. Second, conventional stocks-based analyses are subject to a stock-flow fallacy, neglecting offsetting forces of worker flows on the participation rate. Third, increases in labor force attachment among the unemployed during recessions are a leading explanation for the role of the participation margin.},
  doi      = {http://dx.doi.org/10.1016/j.jmoneco.2015.01.004},
  keywords = {Worker flows, Unemployment, Business cycles, Labor force participation},
  url      = {http://www.sciencedirect.com/science/article/pii/S0304393215000070},
}

