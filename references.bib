@article{barabasi_albert_1999,
  ISSN = {0036-8075},
  annote = {Systems as diverse as genetic networks or the World Wide
  Web are best described as networks with complex topology. A common
  property of many large networks is that the vertex connectivities
  follow a scale-free power-law distribution. This feature was found
  to be a consequence of two generic mechanisms: (i) networks expand
  continuously by the addition of new vertices, and (ii) new vertices
  attach preferentially to sites that are already well connected. A
  model based on these two ingredients reproduces the observed
  stationary scale-free distributions, which indicates that the
  development of large networks is governed by robust self-organizing
  phenomena that go beyond the particulars of the individual
  systems.},
  author = {Albert-L{\'{a}}szl{\'{o}} Barab{\'{a}}si and R{\'{e}}ka Albert},
  copyright = {Copyright 1999 American Association for the Advancement of Science},
  group = {Research; Reports},
  journal = {Science},
  jstor_articletype = {Full Length Article},
  jstor_date = {19991015},
  jstor_formatteddate = {Oct. 15, 1999},
  month = {October},
  number = {5439},
  pages = {509--512},
  publisher = {American Association for the Advancement of Science},
