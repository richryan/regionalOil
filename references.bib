@Article{blackwood_hastings_costello_2010,
  author   = {Julie Blackwood and Alan Hastings and Christopher Costello},
  journal  = {Ecological Economics},
  title    = {Cost-effective management of invasive species using linear-quadratic control},
  year     = {2010},
  issn     = {0921-8009},
  number   = {3},
  pages    = {519 - 527},
  volume   = {69},
  abstract = {The removal of invasive species is the first step toward restoring an ecosystem following invasion. We develop spatially-explicit, dynamic optimal control strategies for a large class of invasion problems using linear-quadratic control. This approach allows us to produce new insights that help guide policy that could not have emerged from existing models. We assume adults are sedentary, and heterogeneous patches are connected via dispersal of offspring. We develop a generalized approach to optimally manage species across time and space and apply the framework to several examples, primarily based on Spartina alterniflora. General conclusions are drawn and we show that strong connectivity makes invasive control much more costly, demonstrating that reducing connectivity can be a cost-effective part of invasive species control.},
  doi      = {http://dx.doi.org/10.1016/j.ecolecon.2009.08.029},
  keywords = {Linear-quadratic control, Invasive species, Spatially explicit, Connectivity},
  url      = {http://www.sciencedirect.com/science/article/pii/S0921800909003590},
}

@Article{hall_hastings_2007,
  author   = {Richard J. Hall and Alan Hastings},
  journal  = {Journal of Theoretical Biology},
  title    = {Minimizing invader impacts: Striking the right balance between removal and restoration},
  year     = {2007},
  issn     = {0022-5193},
  number   = {3},
  pages    = {437 - 444},
  volume   = {249},
  abstract = {Invasive species can cause severe damage in their introduced range; this damage often persists even after removal of the invader. In order to efficiently allocate a limited budget between invader removal and restoration of habitat from which the invader has been removed, it is vital to quantify the impacts of the invasion within an economic context. Here we develop optimal management strategies for biological invasions, which minimize both the direct economic costs of removal and restoration, and the ecological costs of present and future damage caused by the invasion. We demonstrate how this can be formulated as a linear programming problem, enabling the fast and efficient computation of optimal solutions. Using a simple example, we outline some general principles for the optimal control of an invader that damages its environment. Notably, we show that the most effective strategies often switch the priority of removal and restoration over time, and outline the conditions under which restoration is prioritized over removal. The proportion of total funds allocated to restoration will depend on the annual budget, the persistence of damage, and the relative costs of damage, removal and restoration.},
  doi      = {http://dx.doi.org/10.1016/j.jtbi.2007.09.003},
  keywords = {Invasion, Control, Eradication, Restoration, Linear programming},
  url      = {http://www.sciencedirect.com/science/article/pii/S0022519307004213},
}

@Article{hastings_hall_taylor_2006,
  author   = {Alan Hastings and Richard J. Hall and Caz M. Taylor},
  journal  = {Theoretical Population Biology},
  title    = {A simple approach to optimal control of invasive species},
  year     = {2006},
  issn     = {0040-5809},
  number   = {4},
  pages    = {431 - 435},
  volume   = {70},
  abstract = {The problem of invasive species and their control is one of the most pressing applied issues in ecology today. We developed simple approaches based on linear programming for determining the optimal removal strategies of different stage or age classes for control of invasive species that are still in a density-independent phase of growth. We illustrate the application of this method to the specific example of invasive Spartina alterniflora in Willapa Bay, WA. For all such systems, linear programming shows in general that the optimal strategy in any time step is to prioritize removal of a single age or stage class. The optimal strategy adjusts which class is the focus of control through time and can be much more cost effective than prioritizing removal of the same stage class each year.},
  doi      = {http://dx.doi.org/10.1016/j.tpb.2006.05.003},
  keywords = {Biological invasions, Eradication, Linear programming, Spartina alterniflora},
  url      = {http://www.sciencedirect.com/science/article/pii/S0040580906000694},
}

@Article{haight_polasky_2010,
  author   = {Robert G. Haight and Stephen Polasky},
  journal  = {Resource and Energy Economics},
  title    = {Optimal control of an invasive species with imperfect information about the level of infestation},
  year     = {2010},
  issn     = {0928-7655},
  note     = {The Economics of Invasive Species Control and ManagementPapers from a Workshop at Michigan State University},
  number   = {4},
  pages    = {519 - 533},
  volume   = {32},
  abstract = {The presence of invasive species is often not realized until well after the species becomes established. Discovering the location and extent of infestation before the invasive species causes widespread damage typically requires intensive monitoring efforts. In this paper, we analyze the problem of controlling an invasive species when there is imperfect information about the degree of infestation. We model the problem as a partially observable Markov decision process in which the decision-maker receives an imperfect signal about the level of infestation. The decision-maker then chooses a management action to minimize expected costs based on beliefs about the level of infestation. We apply this model to a simple application with three possible levels of infestation where the decision-maker can choose to take no action, only monitor, only treat, or do both monitoring and treatment jointly. We solve for optimal management as a function of beliefs about the level of infestation. For a case with positive monitoring and treatment costs, we find that the optimal policy involves choosing no action when there is a sufficiently large probability of no infestation, monitoring alone with intermediate probability values and treatment alone when the probability of moderate or high infestation is large. We also show how optimal management and expected costs change as the cost or quality of information from monitoring changes. With costless and perfect monitoring, expected costs are 20   30% lower across the range of belief states relative to the expected costs without monitoring.},
  doi      = {http://dx.doi.org/10.1016/j.reseneeco.2010.04.005},
  keywords = {Invasive species, Monitoring, Optimal management, Dynamic programming, Partially observable Markov decision process},
  url      = {http://www.sciencedirect.com/science/article/pii/S0928765510000254},
}

@Article{cho_cooley_kim_2015,
  author   = {Jang-Ok Cho and Thomas F. Cooley and Hyung Seok E. Kim},
  journal  = {Review of Economic Dynamics},
  title    = {Business cycle uncertainty and economic welfare},
  year     = {2015},
  issn     = {1094-2025},
  number   = {2},
  pages    = {185 - 200},
  volume   = {18},
  abstract = {Abstract We study the welfare implications of uncertainty in business cycle models. In the modern business cycle literature, multiplicative real shocks to production and/or preferences play an important role as the impulses that produce aggregate fluctuations. Introducing shocks in this way has the implication that fluctuating economies may enjoy higher welfare than their steady state counterparts. This occurs because purposeful agents make use of uncertainty in their favor. The result holds for a range of reasonable parameter values and in various models considered in the business cycle literature. One notable implication is that the welfare cost estimates which have been obtained in the literature using only consumption series may be biased and possibly seriously.},
  doi      = {http://dx.doi.org/10.1016/j.red.2014.05.002},
  keywords = {Business cycles, Welfare costs, Mean effect, Fluctuations effect, Multiplicative productivity shocks},
  url      = {http://www.sciencedirect.com/science/article/pii/S1094202514000271},
}

@Article{costello_polasky_2008,
  author   = {Christopher Costello and Stephen Polasky},
  journal  = {Journal of Environmental Economics and Management},
  title    = {Optimal harvesting of stochastic spatial resources},
  year     = {2008},
  issn     = {0095-0696},
  number   = {1},
  pages    = {1 - 18},
  volume   = {56},
  abstract = {We characterize the optimal harvest of a renewable resource in a generalized stochastic spatially explicit model. Despite the complexity of the model, we are able to obtain sharp analytical results. We find that the optimal harvest rule in general depends upon dispersal patterns of the resource across space, and only in special circumstances do we find a modified golden rule of growth that is independent of dispersal patterns. We also find that the optimal harvest rule may include closure of some areas to harvest, either on a temporary or permanent basis (biological reserves). Reserves alone cannot correct open access, but may, under sufficient spatial heterogeneity and connectivity, increase profits if appropriate harvest controls are in place outside of reserves.},
  doi      = {http://dx.doi.org/10.1016/j.jeem.2008.03.001},
  keywords = {Marine reserves, Spatial externalities, Stochastic dynamic programming, Renewable resources, Bioeconomic modeling},
  url      = {http://www.sciencedirect.com/science/article/pii/S0095069608000235},
}

@Article{gomme_klein_2011,
  author   = {Paul Gomme and Paul Klein},
  journal  = {Journal of Economic Dynamics and Control},
  title    = {Second-order approximation of dynamic models without the use of tensors},
  year     = {2011},
  issn     = {0165-1889},
  number   = {4},
  pages    = {604 - 615},
  volume   = {35},
  abstract = {Several approaches to finding the second-order approximation to a dynamic model have been proposed recently. This paper differs from the existing literature in that it makes use of the Magnus and Neudecker (1999) definition of the Hessian matrix. The key result is a linear system of equations that characterizes the second-order coefficients. No use is made of multi-dimensional arrays or tensors, a practical implication of which is that it is much easier to transcribe the mathematical representation of the solution into usable computer code. Matlab code is available from http://paulklein.se/newsite/codes/codes.php; Fortran 90 code is available from http://alcor.concordia.ca/   pgomme/.},
  doi      = {http://dx.doi.org/10.1016/j.jedc.2010.10.006},
  keywords = {Solving dynamic models, Second-order approximation},
  url      = {http://www.sciencedirect.com/science/article/pii/S0165188910002344},
}

@article{maliar_maliar_2000,
title = "Differential responses of labor supply across productivity groups",
journal = "Journal of Macroeconomics",
volume = "22",
number = "1",
pages = "85 - 108",
year = "2000",
note = "",
issn = "0164-0704",
doi = "http://dx.doi.org/10.1016/S0164-0704(00)00124-5",
url = "http://www.sciencedirect.com/science/article/pii/S0164070400001245",
author = "Lilia Maliar and Serguei Maliar",
abstract = "There is a substantial amount of microeconomic evidence documenting differential responses of labor supply across productivity groups. In particular, more productive individuals: (i) enjoy a higher employment rate, (ii) have a lower volatility of employment and (iii) spend less time working at home. This paper constructs a real business cycle model with permanent heterogeneity in individual productivity. We calibrate the model with five productivity groups to match key aggregate features of the U.S. economy. We find that the model delivers most of the properties of the data."
}

@article{hansen_prescott_2005,
title = "Capacity constraints, asymmetries, and the business cycle",
journal = "Review of Economic Dynamics",
volume = "8",
number = "4",
pages = "850 - 865",
year = "2005",
note = "",
issn = "1094-2025",
doi = "http://dx.doi.org/10.1016/j.red.2005.08.001",
url = "http://www.sciencedirect.com/science/article/pii/S1094202505000578",
author = "Gary D. Hansen and Edward C. Prescott",
keywords = "Capacity utilization",
keywords = "Asymmetric business cycles",
keywords = "Real business cycles",
abstract = "We study how an occasionally binding capacity constraint affects the properties of business cycles. A real business cycle model is constructed where production takes place at individual plants and the number of plants operated varies over the cycle. The capacity constraint binds in states where all plants are operated. We derive the aggregate production function for this economy, which turns out to differ from the standard Cobb   Douglas function while retaining its desirable properties. The business cycle features of this one-sector growth model are similar to those of a standard real business cycle model in most respects. Our model does, however, display some properties of actual economies that standard models do not. In particular, business cycles in our model are asymmetric   troughs are deeper on average than peaks are tall. Also, labor's share of income is counter-cyclical, as it is in US data."
}

@article{fang_rogerson_2011,
 ISSN = {19457707, 19457715},
 URL = {http://www.jstor.org/stable/41237146},
 abstract = {Recent empirical work finds a negative correlation between product market regulation and aggregate employment. We examine the effect of product market regulations on hours worked in a benchmark model of time allocation. Product market regulations affect market work in effectively the same fashion as labor or consumption taxes. For product market regulations to affect aggregate market work, the key driving force is the size of income transfers associated with the regulations, and the key propagation mechanism is the labor supply elasticity. We show that industry level analysis is of little help in assessing the aggregate effects of product market regulation.},
 author = {Lei Fang and Richard Rogerson},
 journal = {American Economic Journal: Macroeconomics},
 number = {2},
 pages = {163-188},
 publisher = {American Economic Association},
 title = {Product Market Regulation and Market Work: A Benchmark Analysis},
 volume = {3},
 year = {2011}
}

