@Article{morand_reffett_2007,
  author   = {Olivier F. Morand and Kevin L. Reffett},
  journal  = {Journal of Mathematical Economics},
  title    = {Stationary Markovian equilibrium in overlapping generation models with stochastic nonclassical production and Markov shocks},
  year     = {2007},
  issn     = {0304-4068},
  note     = {Instability and Fluctuations in Intertemporal Equilibrium Models},
  number   = {3},
  pages    = {501 - 522},
  volume   = {43},
  abstract = {This paper provides new sufficient conditions for the existence and computation of Markovian equilibrium for a large class of OLG models with Markov shocks to production. The economies considered allow for a very large class of “reduced-form” production functions, including those that are nonclassical, encompassing stochastic OLG models with social security, income redistribution policies, taxation, valued fiat money, production nonconvexities, and monopolistic competition. Our approach combines aspects of both topological and order theoretic fixed point theory and provides globally stable successive approximations algorithms for computing extremal Markovian equilibrium objects.},
  doi      = {https://doi.org/10.1016/j.jmateco.2006.07.005},
  keywords = {Markov equilibrium, Overlapping generations},
  url      = {http://www.sciencedirect.com/science/article/pii/S0304406806000929},
}

@article{selcuk_2014,
title = "Seasonal cycles in a model of the housing market",
journal = "Economics Letters",
volume = "123",
number = "2",
pages = "195 - 199",
year = "2014",
issn = "0165-1765",
doi = "https://doi.org/10.1016/j.econlet.2014.02.007",
url = "http://www.sciencedirect.com/science/article/pii/S0165176514000639",
author = "Cemil Selcuk",
keywords = "Housing, Search and matching, Thin and thick markets, Seasonality",
abstract = "The US housing market exhibits seasonal boom and bust cycles where prices and the speed of trade (turnover rate) rise in summers and fall in winters. We present a search model that analytically generates the observed cycles. The proposed mechanism is based on swings in market thickness rather than market tightness, the leading explanation in the literature."
}

