@Article{frank_1987,
  author              = {Frank, Robert H.},
  journal             = {The American Economic Review},
  title               = {If Homo Economicus Could Choose His Own Utility Function, Would He Want One with a Conscience},
  year                = {1987},
  issn                = {0002-8282},
