@article{ludwig_1975,
     jstor_articletype = {primary_article},
     title = "{Persistence of Dynamical Systems under Random Perturbations}",
     author = {Ludwig, Donald},
     journal = {SIAM Review},
     jstor_issuetitle = {},
     volume = {17},
     number = {4},
     jstor_formatteddate = {Oct., 1975},
     pages = {605--640},
     url = {http://www.jstor.org/stable/2029260},
     ISSN = {00361445},
     abstract = {Random perturbations may decisively affect the long-term behavior of dynamical systems. Random effects are modeled by the addition of Gaussian white noise to the system. The resulting diffusion equation is solved asymptotically, when the strength of the noise is small. Such solutions can be found by a ray method. The rays, in turn, can be interpreted as paths of maximum likelihood. The lowest eigenvalue for the system can then be approximated by means of the asymptotic solution of the diffusion equation. The reciprocal of this eigenvalue gives the persistence of the system.},
     publisher = {Society for Industrial and Applied Mathematics},
     language = {},
     copyright = {Copyright 1975 Society for Industrial and Applied Mathematics},
     year = {1975},
    }

