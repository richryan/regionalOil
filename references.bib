@article{thomas_worrall_1988,
     jstor_articletype = {research-article},
     title = {Self-Enforcing Wage Contracts},
     author = {Thomas, Jonathan and Worrall, Tim},
     journal = {The Review of Economic Studies},
     jstor_issuetitle = {},
     volume = {55},
     number = {4},
     jstor_formatteddate = {Oct., 1988},
     pages = {pp. 541-553},
     url = {http://www.jstor.org/stable/2297404},
     ISSN = {00346527},
     abstract = {We examine long-term wage contracts between a risk-neutral firm and a risk-averse worker when both can costlessly renege and buy or sell labour at a random spot market wage. A self-enforcing contract is one in which neither party ever has an incentive to renege. In the optimum self-enforcing contract, wages are sticky: they are less variable than spot market wages and positively serially correlated. They are updated by a simple rule: around each spot wage is a time invariant interval, and the contract wage changes each period by the smallest amount necessary to bring it into the current interval.},
     language = {English},
     year = {1988},
     publisher = {Oxford University Press},
     copyright = {Copyright    1988 The Review of Economic Studies, Ltd.},
    }

@Article{baxter_1996,
  author              = {Baxter, Marianne},
  journal             = {The Review of Economics and Statistics},
  title               = {Are Consumer Durables Important for Business Cycles},
  year                = {1996},
  issn                = {00346535},
  number              = {1},
  pages               = {pp. 147-155},
  volume              = {78},
  abstract            = {This paper investigates whether consumer durables are important for the generation and propagation of business cycles. We construct a two-sector model that succeeds in generating business cycles that mimic empirical patterns of cross-sector volatility and comovement. We find that half the relatively higher volatility associated with the durable-goods sector is due to higher volatility of shocks hitting this sector, with the other half due to endogenous responses, notably the investment accelerator. Nevertheless, this model does not have stronger internal propagation than the one-sector model. Further, incorporating durable consumer goods has little effect on the behavior of other macroeconomic variables.},
  copyright           = {Copyright 1996 The MIT Press},
  jstor_articletype   = {research-article},
  jstor_formatteddate = {Feb., 1996},
  language            = {English},
  publisher           = {The MIT Press},
  url                 = {http://www.jstor.org/stable/2109854},
}

@article{mankiw_1985,
     jstor_articletype = {research-article},
     title = {Consumer Durables and the Real Interest Rate},
     author = {Mankiw, N. Gregory},
     journal = {The Review of Economics and Statistics},
     jstor_issuetitle = {},
     volume = {67},
     number = {3},
     jstor_formatteddate = {Aug., 1985},
     pages = {pp. 353-362},
     url = {http://www.jstor.org/stable/1925963},
     ISSN = {00346535},
     abstract = {One channel through which real interest rates affect aggregate demand is consumer expenditure on durable goods. This paper examines empirically the link between interest rates and consumer durables. Solving for the decision rule relating income and interest rates to consumer demand is in general an intractable task. This paper avoids this problem by examining the first-order conditions necessary for maximization by the representative consumer. The estimated model suggests that expenditure on consumer durables is far more sensitive to change in the interest rate than is expenditure on nondurables and services.},
     language = {English},
     year = {1985},
     publisher = {The MIT Press},
     copyright = {Copyright    1985 The MIT Press},
    }

@article{bernanke_1985,
title = "Adjustment costs, durables, and aggregate consumption",
journal = "Journal of Monetary Economics",
volume = "15",
number = "1",
pages = "41 - 68",
year = "1985",
note = "",
issn = "0304-3932",
doi = "http://dx.doi.org/10.1016/0304-3932(85)90052-2",
url = "http://www.sciencedirect.com/science/article/pii/0304393285900522",
author = "Ben Bernanke",
abstract = "Previous tests of the permanent-income hypothesis (PIH) have focused on either non-durables or durables expenditures in isolation. This paper studies consumer purchases of non-durables and durables as the outcome of a single optimization problem. It is shown that, with non-separability in utility, the presence of adjustment costs of changing durables stocks may affect the time series properties of both components of expenditure. An econometric test of the PIH based on the model developed in the paper is both more efficient and less prone to bias than those in some previous studies; however, this test confirms earlier rejections of the PIH in aggregate quarterly data."
}

@Article{chen_song_2013,
  author   = {Kaiji Chen and Zheng Song},
  journal  = {Journal of Monetary Economics},
  title    = {Financial frictions on capital allocation: A transmission mechanism of \{TFP\} fluctuations},
  year     = {2013},
  issn     = {0304-3932},
  number   = {6},
  pages    = {683 - 703},
  volume   = {60},
  abstract = {Abstract This paper provides a theory of financial frictions as a transmission mechanism for news shocks to drive aggregate \{TFP\} fluctuations. We show that in an economy calibrated to U.S. data, variations in financial frictions on capital allocation in response to news about future technology can generate aggregate \{TFP\} fluctuations and, thus, trigger business cycles before the actual technological change is realized. Using the \{COMPUSTAT\} dataset, we find that the relative capital productivity of financially constrained to unconstrained firms is highly countercyclical. Moreover, our \{VAR\} analysis shows that news shocks can account for a substantial fraction of the relative capital productivity fluctuations over business cycle frequencies.},
  doi      = {http://dx.doi.org/10.1016/j.jmoneco.2013.06.001},
  keywords = {Financial Friction, Capital Allocation, TFP Fluctuation, News Shock},
  url      = {http://www.sciencedirect.com/science/article/pii/S0304393213000858},
}

