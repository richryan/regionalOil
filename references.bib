@Article{Sargent_wang_yang_2021,
  author       = {Sargent, Thomas J. and Wang, Neng and Yang, Jinqiang},
  journal      = {Proceedings of the National Academy of Sciences},
  title        = {Earnings growth and the wealth distribution},
  year         = {2021},
  issn         = {0027-8424},
  number       = {15},
  volume       = {118},
  abstract     = {Forces that shape wealth inequality are intermediated through an individual{\textquoteright}s nonfinancial earnings growth rate g and an equilibrium interest rate r. Individuals{\textquoteright} earnings growth rate and survival probability interact with their preferences about consumption plans to determine aggregate savings and the interest rate and make wealth more unequally distributed and have a fatter tail than labor earnings, as in US data.As measured by Gini coefficients, fractile inequalities, and tail power laws, wealth is distributed less equally across people than are labor earnings. We study how luck, attitudes that shape saving decisions, and growth rates of labor earnings balance each other in ways that simultaneously shape joint distributions across people of labor earnings, age, and wealth together with an equilibrium rate of return on savings that plays a pivotal role in balancing contending forces. Strong motives for people to save and for firms to demand capital raise an equilibrium interest rate enough to make wealth grow faster than labor earnings. That makes cross-sectional wealth more unevenly distributed and have a fatter tail than labor earnings, as in US data.All study data are included in the article.},
  doi          = {10.1073/pnas.2025368118},
  elocation-id = {e2025368118},
  eprint       = {https://www.pnas.org/content/118/15/e2025368118.full.pdf},
