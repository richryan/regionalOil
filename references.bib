DOI = {{10.1139/f94-130}},
ISSN = {{0706-652X}},
Keywords-Plus = {{DE-LA-MADELEINE; SHELF; MOVEMENTS; FISHERY; MAINE; RECRUITMENT;
   VARIABILITY; CIRCULATION; DYNAMICS; STOCKS}},
